<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="001-add-is-admin" author="automated">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="users" columnName="is_admin"/></not>
        </preConditions>
        <addColumn tableName="users">
            <column name="is_admin" type="boolean" defaultValueBoolean="false"/>
        </addColumn>
        <update tableName="users">
            <column name="is_admin" value="false"/>
            <where>is_admin IS NULL</where>
        </update>
        <addNotNullConstraint tableName="users" columnName="is_admin" columnDataType="boolean"/>
    </changeSet>

    <changeSet id="hidden-test-cases" author="pavitar sekhon">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="io_pair" columnName="hidden"/></not>
        </preConditions>
        <addColumn tableName="io_pair">
            <column name="hidden" type="boolean" defaultValueBoolean="false"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>